# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith Observability
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=BaluAgent

# Job Search Config
INDEED_API_KEY=your_indeed_api_key
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Email Digest
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
DIGEST_RECIPIENT=your@email.com

# Agent Config
MAX_JOBS_PER_RUN=50
JOB_SCAN_INTERVAL_HOURS=24
MIN_MATCH_SCORE=0.75
TARGET_ROLES=Senior SRE,Platform Engineer,DevOps Engineer,AI/ML Engineer
TARGET_LOCATIONS=Remote,San Francisco,New York,Seattle

# MCP Server
MCP_SERVER_PORT=8765
MCP_SECRET_KEY=your_mcp_secret_key

# A2A Protocol
A2A_AGENT_ID=balu-agent-001
A2A_COORDINATOR_URL=http://localhost:9000
